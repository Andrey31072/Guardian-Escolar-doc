        <mxCell id="MqLB0j82V-3Lc3sscl9E-105" parent="1" style="shape=rectangle;whiteSpace=wrap;html=1;" value="&lt;div&gt;RF10.4&lt;/div&gt;Envío y Recepción de Notificaciones" vertex="1">
